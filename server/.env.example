# MongoDB Atlas Connection String
# Get this from your MongoDB Atlas dashboard: https://cloud.mongodb.com/
MONGODB_URI=your_mongodb_uri

# Cloudinary Configuration
# Get these values from your Cloudinary dashboard: https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AbstractAPI Email Verification (optional — skipped if empty)
# Sign up free at: https://app.abstractapi.com/api/email-validation/tester
ABSTRACTAPI_EMAIL_KEY=your_abstractapi_key
